PORT=3001

# Prisma reads this URL from prisma/schema.prisma.
# If the API runs directly on the VPS and MySQL runs in Docker with port 3306 exposed:
DATABASE_URL="mysql://smartvest_user:change_this_password@127.0.0.1:3306/smartvest_db"

# Docker Compose MySQL settings.
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=smartvest_db
MYSQL_USER=smartvest_user
MYSQL_PASSWORD=change_this_password
MYSQL_PORT=3306
